{
  "manifest_version": 3,
  "name": "Applyr Capture",
  "version": "1.3.0",
  "description": "Capture job applications and generate tailored resumes",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["activeTab", "downloads", "scripting", "storage", "tabs"],
  "host_permissions": [
    "https://useapplyr.vercel.app/*",
    "https://ygtsngeuhpvqkvyodjrs.supabase.co/*",
    "https://boards-api.greenhouse.io/*",
    "https://api.lever.co/*",
    "https://api.ashbyhq.com/*",
    "https://*.lambda-url.*.on.aws/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_popup": "popup.html"
  }
}
