{
  "manifest_version": 3,
  "name": "Applyr Capture",
  "version": "1.2.0",
  "description": "Capture job applications and save to your dashboard + sheet",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "https://useapplyr.vercel.app/*",
    "https://ygtsngeuhpvqkvyodjrs.supabase.co/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_popup": "popup.html"
  }
}
